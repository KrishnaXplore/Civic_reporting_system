PORT=5000

# MongoDB
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/civicconnect?retryWrites=true&w=majority&appName=<AppName>

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=7d

# Cloudinary (image uploads)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ML Service
ML_SERVICE_URL=http://localhost:8000

# URLs
SERVER_URL=http://localhost:5000
CLIENT_URL=http://localhost:5173

# Email — Gmail App Password (needed for password reset emails)
# Enable 2FA on Gmail → Security → App Passwords → Generate
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_gmail_app_password
